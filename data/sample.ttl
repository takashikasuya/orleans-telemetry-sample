@prefix sbco: <https://www.sbco.or.jp/ont/> .
@prefix ex: <http://www.sbco.or.jp/sample/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rec: <https://w3id.org/rec#> .

ex:site_TokyoSite1 a sbco:Site ;
  sbco:id "TokyoSite1" ;
  sbco:name "TokyoSite1" ;
  sbco:hasPart ex:buidling_MainBldg .

ex:buidling_MainBldg a sbco:Building ;
  sbco:id "MainBldg" ;
  sbco:name "MainBldg" ;
  sbco:hasPart ex:level_1F ;
  sbco:hasPart ex:level_2F .

ex:level_1F a sbco:Level ;
  sbco:id "level_1F" ;
  sbco:name "1F" ;
  sbco:levelNumber "1"^^xsd:integer ;
  sbco:hasPart ex:room_1F_Room101 .

ex:room_1F_Room101 a sbco:Room ;
  sbco:id "room_1F_Room101" ;
  sbco:name "Room101" .

ex:level_2F a sbco:Level ;
  sbco:id "level_2F" ;
  sbco:name "2F" ;
  sbco:levelNumber "2"^^xsd:integer ;
  sbco:hasPart ex:room_2F_Room201 .

ex:room_2F_Room201 a sbco:Room ;
  sbco:id "room_2F_Room201" ;
  sbco:name "Room201" .

ex:DEV001 a sbco:EquipmentExt ;
  sbco:id "DEV001" ;
  sbco:name "Temperature Sensor 01" ;
  sbco:deviceType "TemperatureSensor" ;
  sbco:locatedIn ex:room_1F_Room101 ;
  sbco:hasPoint ex:PT001 ;
  sbco:hasPoint ex:PT002 .

ex:DEV002 a sbco:EquipmentExt ;
  sbco:id "DEV002" ;
  sbco:name "Humidity Sensor 01" ;
  sbco:deviceType "HumiditySensor" ;
  sbco:locatedIn ex:room_1F_Room101 ;
  sbco:hasPoint ex:PT003 .

ex:DEV003 a sbco:EquipmentExt ;
  sbco:id "DEV003" ;
  sbco:name "CO2 Sensor 01" ;
  sbco:locatedIn ex:room_1F_Room101 ;
  sbco:hasPoint ex:PT004 .

ex:DEV004 a sbco:EquipmentExt ;
  sbco:id "DEV004" ;
  sbco:name "Illumination Sensor 01" ;
  sbco:locatedIn ex:room_1F_Room101 ;
  sbco:hasPoint ex:PT005 .

ex:DEV005 a sbco:EquipmentExt ;
  sbco:id "DEV005" ;
  sbco:name "VAV Unit 01" ;
  sbco:locatedIn ex:room_2F_Room201 ;
  sbco:hasPoint ex:PT006 ;
  sbco:hasPoint ex:PT007 .

ex:DEV006 a sbco:EquipmentExt ;
  sbco:id "DEV006" ;
  sbco:name "Temperature Sensor 02" ;
  sbco:locatedIn ex:room_2F_Room201 ;
  sbco:hasPoint ex:PT008 .

ex:DEV007 a sbco:EquipmentExt ;
  sbco:id "DEV007" ;
  sbco:name "Motion Sensor 01" ;
  sbco:locatedIn ex:room_2F_Room201 ;
  sbco:hasPoint ex:PT009 .

ex:PT001 a sbco:PointExt ;
  sbco:id "PT001" ;
  sbco:name "Room Temperature" ;
  sbco:pointType "Temperature" ;
  sbco:pointSpecification "Measurement" ;
  sbco:unit "℃" ;
  sbco:minPresValue "-10" ;
  sbco:maxPresValue "50" ;
  sbco:scale "1.0"^^xsd:float ;
  sbco:description "Room 101 temperature sensor" ;
  rec:customTags [
    a sbco:KeyBoolMapEntry ;
    sbco:key "temperature" ;
    sbco:flag true
  ], [
    a sbco:KeyBoolMapEntry ;
    sbco:key "room101" ;
    sbco:flag true
  ] ;
  rec:customProperties [
    a sbco:KeyMapOfStringMapEntry ;
    sbco:key "point_list" ;
    sbco:entries [ a sbco:KeyStringMapEntry ; sbco:key "writable" ; sbco:value "false" ] ;
    sbco:entries [ a sbco:KeyStringMapEntry ; sbco:key "interval" ; sbco:value "60" ] ;
    sbco:entries [ a sbco:KeyStringMapEntry ; sbco:key "supplier" ; sbco:value "VendorA" ] ;
    sbco:entries [ a sbco:KeyStringMapEntry ; sbco:key "owner" ; sbco:value "Building Management" ]
  ] .

