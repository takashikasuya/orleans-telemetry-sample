    private static string FormatBytes(long? bytes) => FormatBytes((double?)bytes);

    private static string FormatBytes(double? bytes)
    {
        if (!bytes.HasValue)
        {
            return "-";
        }

        var value = bytes.Value;
        var units = new[] { "B", "KB", "MB", "GB", "TB" };
        var index = 0;
        while (value >= 1024 && index < units.Length - 1)
        {
            value /= 1024;
            index++;
        }

        return $"{value:F1} {units[index]}";
    }

    private static string FormatPercent(double? value)
        => value.HasValue ? $"{value.Value:F1}%" : "-";

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        return FormatTimestamp(value.Value);
    }

    private static string FormatTimestamp(DateTimeOffset value)
        => value.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss", System.Globalization.CultureInfo.InvariantCulture) + " UTC";

    private static string FormatMemoryUsage(double? used, double? available)
    {
        if (!used.HasValue && !available.HasValue)
        {
            return "-";
        }

        var usedText = FormatBytes(used);
        if (!available.HasValue)
        {
            return usedText;
        }

        return $"{usedText} / {FormatBytes(available)}";
    }

    private static string GetGraphStatusLabel(GraphSeedStatus? status)
        => status is null ? "Not run" : status.Success ? "Success" : "Failure";

    private static string GetGraphStatusBadgeClass(GraphSeedStatus? status)
        => status is null ? "status-badge muted" : status.Success ? "status-badge success" : "status-badge failure";

    private async Task HandleGraphFileSelected(InputFileChangeEventArgs args)
    {
        _graphUploadError = null;
        _graphUploadMessage = null;

        var file = args.File;
        if (file is null)
        {
            _graphUploadError = "No file selected.";
            return;
        }

        var maxBytes = GetGraphUploadMaxBytes();
        if (file.Size > maxBytes)
        {
            _graphUploadError = $"File too large. Max {FormatBytes(maxBytes)}.";
            return;
        }

        var uploadDir = GetGraphUploadDirectory();
        Directory.CreateDirectory(uploadDir);

        if (!string.IsNullOrWhiteSpace(_uploadedGraphPath))
        {
            TryDeleteFile(_uploadedGraphPath);
        }

        var safeFileName = Path.GetFileName(file.Name);
        var uniqueName = $"{DateTime.UtcNow:yyyyMMddHHmmss}_{Guid.NewGuid():N}_{safeFileName}";
        var targetPath = Path.Combine(uploadDir, uniqueName);

        await using var input = file.OpenReadStream(maxBytes);
        await using var output = File.Create(targetPath);
        await input.CopyToAsync(output);

        _uploadedGraphPath = targetPath;
        _uploadedGraphFileName = safeFileName;
        _graphUploadMessage = $"Uploaded {_uploadedGraphFileName}. Using uploaded file for import.";
    }

    private Task ClearUploadedGraphAsync()
    {
        if (!string.IsNullOrWhiteSpace(_uploadedGraphPath))
        {
            TryDeleteFile(_uploadedGraphPath);
        }

        _uploadedGraphPath = null;
        _uploadedGraphFileName = null;
        _graphUploadMessage = "Upload cleared.";
        _graphUploadError = null;
        return Task.CompletedTask;
    }

    private async Task TriggerGraphSeedAsync()
    {
        _isImporting = true;
        _graphFeedback = null;
        try
        {
            var seedPath = _uploadedGraphPath;
            if (string.IsNullOrWhiteSpace(seedPath))
            {
                _graphFeedback = "Upload an RDF file before running import.";
                return;
            }

            if (_uploadedGraphPath is not null && !File.Exists(_uploadedGraphPath))
            {
                _graphFeedback = "Uploaded file was not found on disk. Please upload again.";
                return;
            }

            var request = new GraphSeedRequest(seedPath, _graphTenant, _graphTenantName);
            var result = await Metrics.TriggerGraphSeedAsync(request);
            _graphStatus = result;
            _graphFeedback = result.Success
                ? "Import completed."
                : $"Import failed: {result.Message ?? "Unknown error"}";
        }
        catch (Exception ex)
        {
            _graphFeedback = $"Import failed: {ex.Message}";
        }
        finally
        {
            _isImporting = false;
        }
    }

    private string GetGraphUploadDirectory()
    {
        var configured = Configuration["ADMIN_GRAPH_UPLOAD_DIR"]
            ?? Configuration["Admin:GraphUploadDirectory"];
        if (!string.IsNullOrWhiteSpace(configured))
        {
            return configured;
        }

        return Path.Combine(Path.GetTempPath(), "orleans-telemetry-uploads");
    }

    private long GetGraphUploadMaxBytes()
    {
        var configured = Configuration["ADMIN_GRAPH_UPLOAD_MAX_BYTES"]
            ?? Configuration["Admin:GraphUploadMaxBytes"];
        return long.TryParse(configured, out var maxBytes) ? maxBytes : DefaultGraphUploadLimitBytes;
    }

    private static void TryDeleteFile(string path)
    {
        try
        {
            if (File.Exists(path))
            {
                File.Delete(path);
            }
        }
        catch
        {
            // Best effort cleanup of temporary uploads.
        }
    }


    private async Task LoadApiRequestLogsAsync()
    {
        _apiLogLoading = true;
        _apiLogError = null;

        try
        {
            int? statusCode = null;
            if (!string.IsNullOrWhiteSpace(_apiLogStatusCodeText) && int.TryParse(_apiLogStatusCodeText, out var parsed))
            {
                statusCode = parsed;
            }

            var query = new ApiRequestLogQuery(
                _apiLogTenant,
                _apiLogPathContains,
                statusCode,
                DateTimeOffset.UtcNow.AddMinutes(-15),
                DateTimeOffset.UtcNow,
                _apiLogLimit);

            _apiRequestLogs = (await Metrics.GetApiRequestLogsAsync(query, CancellationToken.None)).ToList();
            _apiLogStatus = $"Loaded {_apiRequestLogs.Count} rows at {FormatTimestamp(DateTimeOffset.UtcNow)}";
            if (_showIngestVolumePanel)
            {
                await RefreshIngestVolumeFromLogsAsync();
            }
        }
        catch (Exception ex)
        {
            _apiLogError = $"Failed to load API request logs: {ex.Message}";
        }
        finally
        {
            _apiLogLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StartApiLogTimer()
    {
        _apiLogTimerCts?.Cancel();
        _apiLogTimerCts?.Dispose();
        _apiLogTimer?.Dispose();

        _apiLogTimerCts = new CancellationTokenSource();
        _apiLogTimer = new PeriodicTimer(TimeSpan.FromSeconds(5));

        _ = Task.Run(async () =>
        {
            try
            {
                while (_apiLogTimer is not null &&
                       await _apiLogTimer.WaitForNextTickAsync(_apiLogTimerCts.Token))
                {
                    if (_loading)
                    {
                        continue;
                    }

                    if (_showIngestVolumePanel)
                    {
                        await RefreshIngestVolumeFromLogsAsync();
                    }

                    if (!_enableApiLogRealtime || _apiLogLoading)
                    {
                        continue;
                    }

                    await LoadApiRequestLogsAsync();
                }
            }
            catch (OperationCanceledException)
            {
                // Expected when the timer is canceled or disposed.
            }
            catch
            {
                // Swallow other exceptions to avoid unobserved task exceptions from this fire-and-forget loop.
            }
        });
    }

    private async Task EnsureRealtimeSubscriptionAsync()
    {
        if (_dotNetRef is null)
        {
            return;
        }

        await JSRuntime.InvokeVoidAsync("unsubscribeFromPointUpdates");

        if (!_enableTelemetryRealtime)
        {
            _telemetryRealtimeStatus = "Realtime updates are disabled.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedPoints.Count == 0)
        {
            _telemetryRealtimeStatus = "Add a point to start realtime monitoring.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var subscriptions = _selectedPoints
            .Select(item => new RealtimeSubscriptionTarget(item.TenantId, item.DeviceId, item.PointId))
            .Distinct()
            .ToArray();

        try
        {
            await JSRuntime.InvokeVoidAsync("subscribeToPointUpdates", subscriptions, _dotNetRef);
            _telemetryRealtimeStatus = $"Realtime subscribed to {subscriptions.Length} point(s).";
        }
        catch (Exception ex)
        {
            _telemetryRealtimeStatus = $"Realtime subscription failed: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshIngestVolumeFromLogsAsync()
    {
        try
        {
            var summary = await Metrics.GetApiRequestLogVolumeAsync(_apiLogTenant, CancellationToken.None);
            _ingestCountLast1Minute = summary.Last1MinuteCount;
            _ingestCountLast5Minutes = summary.Last5MinutesCount;
            _ingestVolumeUpdatedAtText = FormatTimestamp(summary.CalculatedAt);
            _ingestVolumeNote = summary.MayBeCapped
                ? $"Volume may be truncated by query limit ({summary.QueryLimit})."
                : null;
        }
        catch (Exception ex)
        {
            _ingestVolumeNote = $"Failed to refresh ingest volume: {ex.Message}";
        }
    }

    [JSInvokable]
    public Task OnPointUpdate(PointUpdateDto update)
    {
        if (_selectedPoints.Count > 0)
        {
            var watchedPoint = _selectedPoints.FirstOrDefault(item =>
                item.PointId.Equals(update.PointId, StringComparison.OrdinalIgnoreCase) &&
                item.DeviceId.Equals(update.DeviceId, StringComparison.OrdinalIgnoreCase) &&
                item.TenantId.Equals(update.TenantId, StringComparison.OrdinalIgnoreCase));

            if (watchedPoint is null)
            {
                return Task.CompletedTask;
            }
        }

        var sample = new PointTrendSample(update.Timestamp, ExtractNumericValue(update.Value), update.Value?.ToString());

        var flatSamples = _pointTrendSamples.ToList();
        flatSamples.Add(sample);
        if (flatSamples.Count > 500)
        {
            flatSamples = flatSamples.TakeLast(500).ToList();
        }

        _pointTrendSamples = flatSamples;

        var series = _pointTrendSeries.ToList();
        var target = series.FirstOrDefault(item => item.PointId.Equals(update.PointId, StringComparison.OrdinalIgnoreCase));
        if (target is not null)
        {
            var samples = target.Samples.ToList();
            samples.Add(sample);
            if (samples.Count > 500)
            {
                samples = samples.TakeLast(500).ToList();
            }

            var index = series.IndexOf(target);
            series[index] = target with { Samples = samples };
            _pointTrendSeries = series;
        }

        return InvokeAsync(StateHasChanged);
    }

    private async Task OnIngestVolumePanelChangedAsync()
    {
        if (_showIngestVolumePanel)
        {
            await RefreshIngestVolumeFromLogsAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private sealed record RealtimeSubscriptionTarget(string TenantId, string DeviceId, string PointId);

    private static double? ExtractNumericValue(object? value)
    {
        if (value is null) return null;
        if (value is JsonElement elem)
        {
            return elem.ValueKind switch
            {
                JsonValueKind.Number when elem.TryGetDouble(out var n) => n,
                JsonValueKind.String when double.TryParse(elem.GetString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var s) => s,
                JsonValueKind.True => 1.0,
                JsonValueKind.False => 0.0,
                _ => null
            };
        }

        if (value is bool b) return b ? 1.0 : 0.0;
        if (value is IConvertible convertible)
        {
            try { return Convert.ToDouble(convertible); }
            catch { return null; }
        }

        return value is string str && double.TryParse(str, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : null;
    }

    public async ValueTask DisposeAsync()
    {
        _apiLogTimerCts?.Cancel();
        _apiLogTimer?.Dispose();
        _apiLogTimerCts?.Dispose();
        try
        {
            await JSRuntime.InvokeVoidAsync("unsubscribeFromPointUpdates");
        }
        catch
        {
            // ignore on dispose
        }

        _dotNetRef?.Dispose();
    }

    public sealed class PointUpdateDto
    {
        public DateTimeOffset Timestamp { get; set; }
        public object? Value { get; set; }
        public string PointId { get; set; } = string.Empty;
        public string DeviceId { get; set; } = string.Empty;
        public string TenantId { get; set; } = string.Empty;
    }
}
